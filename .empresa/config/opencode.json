        "write": true
      }
    },
    "qa-engineer": {
      "description": "QA Engineer - testing, coverage y aseguramiento de calidad",
      "tools": {
        "skill": true,
        "read": true,
        "bash": true,
        "context7": true
      }
    },
    "documentador": {
      "description": "Documentador - documentación técnica, README y guías de uso",
      "tools": {
        "skill": true,
