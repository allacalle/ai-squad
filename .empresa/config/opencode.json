      "tools": {
        "skill": true,
        "read": true,
        "bash": true,
        "context7": true
      }
    }
  },
  "mcp": {
    "engram": {
      "command": [
        "C:\\Users\\Usuario\\bin\\engram.exe",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "opencode-mcp": {
      "command": [
        "npx",
        "-y",
        "opencode-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    },
    "bash": {
      "rm *": "ask",
      "del *": "ask",
      "format *": "ask"
    }
  }
}
